# ─────────────────────────────────────────────────────────────
#  UFood — environment template. Copy to .env and fill in values.
# ─────────────────────────────────────────────────────────────

# ── Database (MySQL) ──
# Both the Node bot and the Python coupon-taker connect to the
# same database. On a separate Linux deployment for the Python
# side, set these to the production credentials.
MYSQL_HOST=127.0.0.1
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=sql_undip_foodtruck

# ── Express / Node ──
EXPRESS_PORT=3000
# Used to sign JWTs for the /api/accounts admin endpoints.
ACCESS_TOKEN_SECRET=change-me

# ── Crypto ──
# AES-256-CBC key (64 hex chars / 32 bytes) and IV (32 hex / 16 bytes).
# MUST match between Node and Python or stored emails/passwords break.
# Generate fresh: openssl rand -hex 32   /   openssl rand -hex 16
ENCRYPTION_KEY=
ENCRYPTION_IV=

# ── MongoDB (optional, for whatsapp-web.js RemoteAuth) ──
MONGODB_URI=

# ── WhatsApp / Telegram admin ──
# WhatsApp IDs use the @c.us suffix. ADMIN_WHATSAPP receives payment
# proofs and ping notifications; ADMIN_WHATSAPP_SELF gets self-alerts.
ADMIN_WHATSAPP=
ADMIN_WHATSAPP_SELF=
# Telegram bot is currently optional (commented out in bot.js).
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Browser executables ──
# Path to Chrome/Chromium for Puppeteer. Platform-specific:
#   Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
#   Linux:   /usr/bin/google-chrome  or  /usr/bin/chromium-browser
CHROME_EXECUTABLE_PATH=
CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
# Run Chrome headless (true on server, false on local dev so you can scan WA QR).
CHROME_HEADLESS=false

# ── SSO login proxy (IPRoyal residential) ──
# Leave blank to disable. With the proxy disabled, sso_login_manager
# will launch Puppeteer without --proxy-server.
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# ── Cloudflare Turnstile solver (CapSolver) ──
CAPSOLVER_API_KEY=
TURNSTILE_SITE_KEY=
TURNSTILE_SITE_URL=https://form.undip.ac.id/makanansehat/pendaftaran
# Optional tuning. Defaults: 45s total, 1.5s polling interval.
CAPSOLVER_TIMEOUT_S=45
CAPSOLVER_POLL_INTERVAL_S=1.5
